{
  "pipeline_version": "0.7.0",
  "inputs": [
    "data/extracted/pdf_extracted_records.csv",
    "data/extracted/web_extracted_records.csv"
  ],
  "output": "data/processed/dataset.csv",
  "steps": [
    {
      "step_id": "merge_sources",
      "operation": "concatenate",
      "description": "Combine PDF- and web-extracted CSV files into a single interim table.",
      "input_files": [
        "data/extracted/pdf_extracted_records.csv",
        "data/extracted/web_extracted_records.csv"
      ],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "drop_non_bacterial_pathogens",
      "operation": "filter",
      "description": "Remove rows whose pathogen_name matches yeast/fungal/virus/mammalian substring hints (helpers in scripts/utils.py).",
      "fields": ["pathogen_name"],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "canonical_measurement_units",
      "operation": "string_cleanup",
      "description": "Canonicalize measurement_unit labels; preserve measurement_value as verbatim MIC text.",
      "fields": ["measurement_value", "measurement_unit"],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "standardize_sequences",
      "operation": "sequence_cleanup",
      "description": "Uppercase peptide sequences and remove whitespace or invalid characters.",
      "fields": ["peptide_sequence"],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "standardize_missing_values",
      "operation": "missing_value_cleanup",
      "description": "Map NA, N/A, -, empty strings to null-like values except verbatim MIC tokens.",
      "fields": ["medium_composition"],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "deduplicate_records",
      "operation": "deduplicate",
      "fields": ["all_schema_columns_except_record_id", "record_id"],
      "description": "Drop rows that are identical across all schema fields except record_id (same peptide, pathogen, assay conditions, MIC, source), then deduplicate remaining record_ids.",
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "export_final_dataset",
      "operation": "export",
      "description": "Write schema-aligned columns to the publication dataset CSV (scripts/clean_dataset.py).",
      "input_files": ["data/interim/merged_records.csv"],
      "output_file": "data/processed/dataset.csv"
    },
    {
      "step_id": "validate_schema",
      "operation": "validation",
      "description": "Run rules in specs/validation_rules.json via scripts/validate_project.py on the finalized dataset.",
      "input_files": ["data/processed/dataset.csv"],
      "output_file": "reports/practice_05_cleaning_publication.md"
    }
  ]
}
