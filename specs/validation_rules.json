{
  "validation_version": "0.1.5",
  "rules": [
    {
      "rule_id": "files_exist_core",
      "target": "repository",
      "rule_type": "required_files",
      "severity": "error",
      "description": "Core project files (project.json, schema, source map, manifests, scripts) must exist."
    },
    {
      "rule_id": "dataset_csv_exists",
      "target": "data/processed/dataset.csv",
      "rule_type": "file_exists",
      "severity": "error",
      "description": "Final processed dataset CSV must exist."
    },
    {
      "rule_id": "record_id_not_null",
      "target": "record_id",
      "rule_type": "not_null",
      "severity": "error",
      "description": "Every row must have a non-empty record_id."
    },
    {
      "rule_id": "record_id_unique",
      "target": "record_id",
      "rule_type": "unique",
      "severity": "error",
      "description": "record_id values must be unique across the dataset."
    },
    {
      "rule_id": "peptide_sequence_not_null",
      "target": "peptide_sequence",
      "rule_type": "not_null",
      "severity": "error",
      "description": "Every row must have a non-empty peptide_sequence after normalization."
    },
    {
      "rule_id": "source_id_not_null",
      "target": "source_id",
      "rule_type": "not_null",
      "severity": "error",
      "description": "Every row must reference a source_id."
    },
    {
      "rule_id": "source_id_in_source_map",
      "target": "source_id",
      "rule_type": "foreign_key",
      "severity": "warning",
      "description": "source_id should appear in specs/source_map.json."
    },
    {
      "rule_id": "columns_match_schema",
      "target": "data/processed/dataset.csv",
      "rule_type": "schema_columns",
      "severity": "error",
      "description": "Dataset columns must match field names in specs/dataset_schema.json."
    },
    {
      "rule_id": "measurement_unit_canonical_labels",
      "target": "measurement_unit",
      "rule_type": "enum_optional",
      "severity": "warning",
      "description": "Non-empty measurement_unit labels should belong to the canonical set (scripts/validate_project.py MEASUREMENT_UNITS_ALLOWED)."
    },
    {
      "rule_id": "source_type_allow_list",
      "target": "source_type",
      "rule_type": "enum_optional",
      "severity": "warning",
      "description": "Non-empty source_type values should match schema allowed_values (scripts/validate_project.py SOURCE_TYPES_ALLOWED)."
    },
    {
      "rule_id": "pathogen_name_not_null",
      "target": "pathogen_name",
      "rule_type": "not_null",
      "severity": "error",
      "description": "Every row must have a non-empty pathogen_name."
    },
    {
      "rule_id": "measurement_value_not_null",
      "target": "measurement_value",
      "rule_type": "not_null",
      "severity": "error",
      "description": "Every row must have a non-empty, float-parseable measurement_value after cleaning (numeric MIC scalar)."
    }
  ]
}
